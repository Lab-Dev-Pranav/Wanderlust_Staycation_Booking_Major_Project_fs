<% layout("/layouts/boilerplate") %>
<% block('styles').append('<link rel="stylesheet" href="/css/bookingonmylocation.css">') %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<%
  const totalBookings = surusbk?.length || 0;
  const confirmedBookings = surusbk?.filter(b => b.status === 'confirmed').length || 0;
  const pendingBookings = surusbk?.filter(b => b.status === 'pending').length || 0;
%>

<div class="booking-page">
  <div class="booking-page-shell">
    <header class="booking-hero-card">
      <div class="booking-hero-main">
        <div class="booking-kicker">Host Dashboard</div>
        <h1 class="booking-title">Bookings on My Locations <span id="live-date"></span> <span id="live-time"></span></h1>
        <p class="booking-intro">View and manage all bookings made on your listings.</p>

        <div class="booking-stat-strip">
          <div class="booking-stat-pill">
            <span>Total Bookings</span>
            <strong><%= totalBookings %></strong>
          </div>
          <div class="booking-stat-pill booking-stat-pill-success">
            <span>Confirmed</span>
            <strong><%= confirmedBookings %></strong>
          </div>
          <div class="booking-stat-pill">
            <span>Pending</span>
            <strong><%= pendingBookings %></strong>
          </div>
        </div>

        <div class="booking-hero-actions">
          <a href="/getmypayments/<%= curr_user.email %>" class="booking-btn booking-btn-primary">
            <p>Payments</p>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </header>

    <section class="booking-section" id="bookings-list">
      <div class="booking-section-head">
        <div>
          <p class="booking-section-kicker">Booking Records</p>
          <% if (totalBookings !== 0) { %>
            <h2>All Bookings on Your Listings – <%= totalBookings %></h2>
          <% } else { %>
            <h2>No bookings on your listings yet</h2>
          <% } %>
        </div>
        <div class="booking-count-chip"><%= totalBookings %> total</div>
      </div>

      <% if (totalBookings === 0) { %>
        <div class="booking-empty-state booking-empty-state-light">
          <div class="booking-empty-icon"><i class="bi bi-calendar-x"></i></div>
          <h3>No bookings found</h3>
          <p>When guests book your listings, they'll appear here with full details.</p>
        </div>
      <% } else { %>
        <div class="booking-cards-grid">
          <% for (let BOOKING of surusbk) { 
              const checkInDate = new Date(BOOKING.checkIn); 
              const checkOutDate = new Date(BOOKING.checkOut); 
              const totalDays = Math.ceil((checkOutDate - checkInDate) / (1000 * 60 * 60 * 24));
              const totalPrice = totalDays * BOOKING.listing.price;
              const gstAmount = totalPrice * 0.18;
              const platformFee = totalPrice * 0.02;
              const grandTotal = totalPrice + gstAmount + platformFee;
              const statusClass = BOOKING.status === 'confirmed' ? 'booking-status-confirmed' : (BOOKING.status === 'pending' ? 'booking-status-pending' : 'booking-status-other');
              const statusChipClass = BOOKING.status === 'confirmed' ? 'booking-confirmed-chip' : (BOOKING.status === 'pending' ? 'booking-status-pending' : '');
          %>
            <article class="booking-card-shell">
              <div class="booking-card-media">
                <img 
                  src="<%= BOOKING.listing.image.url %>" 
                  class="booking-card-image" 
                  alt="<%= BOOKING.listing.title %>">
                <div class="booking-card-badges">
                  <span class="booking-chip"><%= BOOKING.listing.tag %></span>
                  <span class="booking-status-pill <%= statusChipClass %>">
                    <%= BOOKING.status.charAt(0).toUpperCase() + BOOKING.status.slice(1) %>
                  </span>
                </div>
              </div>

              <div class="booking-card-body">
                <div class="booking-card-top">
                  <div>
                    <h3><%= BOOKING.listing.title %></h3>
                    <p class="booking-location"><i class="bi bi-geo-alt-fill"></i><span><%= BOOKING.listing.location %>, <%= BOOKING.listing.country %></span></p>
                    <p class="booking-location"><i class="bi bi-map-fill"></i><span><a href="<%= BOOKING.listing.exactLocation %>" target="_blank" class="booking-link">View exact location on map</a></span></p>
                  </div>
                </div>

                <div class="booking-facts-grid">
                  <div class="booking-fact-card">
                    <span>Guests</span>
                    <strong><%= BOOKING.people %> / <%= BOOKING.listing.capacity %></strong>
                    <small>Capacity</small>
                  </div>
                  <div class="booking-fact-card">
                    <span>Nights</span>
                    <strong><%= totalDays %></strong>
                    <small>Stay Duration</small>
                  </div>
                  <div class="booking-fact-card">
                    <span>Booked By</span>
                    <strong><%= BOOKING.user.username %></strong>
                    <small><%= BOOKING.user.email %></small>
                  </div>
                  <div class="booking-fact-card">
                    <span>Booking Date</span>
                    <strong><%= new Date(BOOKING.createdAt).toLocaleDateString("en-IN", { year: "numeric", month: "long", day: "numeric" }) %></strong>
                  </div>
                </div>

                <div class="booking-inline-meta">
                  <p><i class="bi bi-calendar-check"></i> Check-in: <strong><%= checkInDate.toDateString() %></strong> at 01:00 PM</p>
                  <p><i class="bi bi-calendar-x"></i> Check-out: <strong><%= checkOutDate.toDateString() %></strong> at 11:00 AM</p>
                  <% if (BOOKING.expiresAt) { %>
                    <p><i class="bi bi-hourglass-split"></i> Expires: <span class="booking-expiry-timer" data-expiry="<%= new Date(BOOKING.expiresAt).toISOString() %>">--:--:--</span></p>
                  <% } %>
                </div>

                <div class="booking-bottom-grid">
                  <div class="booking-price-breakdown">
                    <p class="mb-2"><strong>Booking date:</strong> <%= new Date(BOOKING.createdAt).toLocaleDateString("en-IN", { year: "numeric", month: "long", day: "numeric" }) %></p>
                    <p class="mb-1 text-success"><strong>Total Price:</strong> ₹<%= totalPrice.toLocaleString("en-IN") %> <small>(base)</small></p>
                    <p class="mb-1 text-muted small">+ 18% GST: ₹<%= gstAmount.toFixed(2).toLocaleString("en-IN") %></p>
                    <p class="mb-1 text-muted small">+ 2% Platform Fee: ₹<%= platformFee.toFixed(2).toLocaleString("en-IN") %></p>
                    <p class="mb-0 fw-bold fs-5 text-success">Grand Total: ₹<%= grandTotal.toFixed(2).toLocaleString("en-IN") %></p>
                  </div>

                  <div class="booking-date-box">
                    <p class="mb-1"><strong>Booking ID:</strong> <code><%= BOOKING._id %></code></p>
                    <p class="mb-0"><strong>Status:</strong> <span class="badge <%= statusClass %>"><%= BOOKING.status.charAt(0).toUpperCase() + BOOKING.status.slice(1) %></span></p>
                  </div>
                </div>
              </div>
            </article>
          <% } %>
        </div>
      <% } %>
    </section>
  </div>
</div>

<script>
  function updateDateTime() {
    const now = new Date();
    const dateOptions = { year: 'numeric', month: 'long', day: 'numeric' };
    const timeOptions = { hour: '2-digit', minute: '2-digit', second: '2-digit' };

    document.getElementById('live-date').textContent = now.toLocaleDateString('en-IN', dateOptions) + ' ';
    document.getElementById('live-time').textContent = now.toLocaleTimeString('en-IN', timeOptions);
  }
  updateDateTime();
  setInterval(updateDateTime, 1000);

  function startExpiryCountdown() {
    const timers = document.querySelectorAll('.booking-expiry-timer');

    timers.forEach(timer => {
      const expiryTime = new Date(timer.dataset.expiry).getTime();

      function updateTimer() {
        const now = Date.now();
        const distance = expiryTime - now;

        if (distance <= 0) {
          timer.textContent = "Expired";
          timer.classList.add('text-danger', 'fw-bold');
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        let output = '';
        if (days > 0) output += `${days}d `;
        output += `${hours.toString().padStart(2, '0')}h : `;
        output += `${minutes.toString().padStart(2, '0')}m : `;
        output += `${seconds.toString().padStart(2, '0')}s`;

        timer.textContent = output;
      }

      updateTimer();
      const intervalId = setInterval(() => {
        updateTimer();
        if (Date.now() >= expiryTime) clearInterval(intervalId);
      }, 1000);
    });
  }

  document.addEventListener("DOMContentLoaded", startExpiryCountdown);
</script>