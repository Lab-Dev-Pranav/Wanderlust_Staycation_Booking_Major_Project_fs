<% layout("/layouts/boilerplate") %>
  <% block('styles').append(` <link rel="stylesheet" href="/css/listings_showx.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    `)
    %>
    <script>
      const MAPTOKEN_A = "<%= process.env.MAP_TOKEN %>";
      const listing = JSON.parse(decodeURIComponent('<%= encodeURIComponent(JSON.stringify(listing)) %>'));
    </script>

    <body class="show-body">

      <div class="show-container">

        <!-- <%= listing %> -->
        <!-- <%= reviews %> -->

        <div class="show-hero">
          <div class="show-hero-o">
            <h3>
              <%= listing.title %>
            </h3>

            <h6>
              ⭐ <%= averageRating %>
                <span>(<%= reviews.length %> Reviews)</span>

                <span class="dot">•</span>
                <span>
                  Host <%= listing.owner.username %>

                    <% if (currUser && currUser.username !==listing.owner.username) { %>
                      <a href="/userprofile/<%= listing.owner._id %>" style="text-decoration: none; color: inherit;">
                        <strong>↗</strong>
                      </a>
                      <% } %>
                </span>

            </h6>
          </div>

          <div class="show-hero-t"></div>
        </div>

        <div class="show-listing">

          <!-- Details -->
          <div class="show-listing-details">
            <div class="show-listing-img">
              <img src="<%= listing.image.url %>" alt="listing image" />
            </div>
            <!-- -------------------------------- -->
            <div class="show-listing-info">
              <h5>
                🌄 <%= listing.tag %> ● 📍 <%= listing.location %>, <%= listing.country %>
                      <span class="tooltip-ibtn" tabindex="0" aria-label="Location info">
                        <i class="bi bi-info-circle-fill ibtn"></i>
                        <span class="tooltip-text">
                          <span class="text-primary">Exact Location will be provided after booking...</span>
                        </span>
                      </span>
              </h5>
            </div>
            <!-- ---------------------------- -->
            <div class="show-listing-rooms">
              <p>Rooms: <%= listing.rooms.length %>
              </p>
              <div class="room-cards-container">
                <% if (listing.rooms && listing.rooms.length) { %>
                  <% listing.rooms.forEach(room=> { %>
                    <div class="room-card">
                      <div class="room-card-icon">
                        🛏️
                      </div>
                      <div class="room-card-info">
                        <h4>
                          Room <%= room.roomNo %>
                        </h4>
                        <p class="room-type">
                          <%= room.roomType %>
                        </p>
                        <p class="room-capacity">
                          👥 <strong>
                            <%= room.capacity %>
                          </strong> Guests
                        </p>
                      </div>
                    </div>
                    <% }) %>
                      <% } else { %>
                        <p>No rooms available.</p>
                        <% } %>
              </div>
            </div>
            <br>
            <!-- -------------------------------- -->
            <div class="show-listing-description">
              <h5>
                About:
              </h5>
              <p>
                <%= listing.description %>
              </p>

            </div>

            <div class="booking-card booking-card-mobile">

              <h3>Reserve your stay</h3>

              <p class="booking-subtitle">
                Secure your booking in just a few clicks.
              </p>

              Pricing: <strong> ₹ <%= listing.price %></strong> / night
              <span class="tooltip-ibtn" tabindex="0" aria-label="Pricing info">
                <i class="bi bi-info-circle-fill ibtn"></i>
                <span class="tooltip-text">
                  <span class="text-primary">18% GST + 2% Platform Fee of the booking price (Base Price) applicable at
                    the
                    time of booking</span>
                </span>
              </span>
              <br>
              <br>

              <form action="/listings/<%= listing._id %>/book" method="get">

                <% if (bookingdata) { %>
                  <input type="hidden" name="bookingdata" value='<%= JSON.stringify(bookingdata) %>'>
                  <% } %>

                    <button type="submit" class="booking-btn">
                      Reserve Now
                    </button>

              </form>
              <hr>

              <% if(currUser && currUser._id.equals(listing.owner._id)){ %>

                <div class="owner-actions">

                  <a href="/listings/<%= listing._id %>/edit" class="edit-btn">

                    Edit Listing

                  </a>

                  <button type="button" class="delete-btn" data-bs-toggle="modal" data-bs-target="#deleteModal">

                    Delete Listing

                  </button>

                </div>

                <% } %>

            </div>
            <br>

            <!-- --------------------------------------- -->
            <div class="show-listing-map">
              <!-- map  -->
              <h4>Where you'll be</h4>
              <div id="map"></div>
            </div>
            <!-- --------------------------------------- -->
            <br><br>
            <% if(currUser){ %>

              <div class="show-listing-add-review">

                <div class="review-form-card">

                  <div class="review-form-header">

                    <div>
                      <h3>Share your experience</h3>
                      <p>Help other travellers by writing an honest review.</p>
                    </div>

                    <div class="review-icon">
                      <i class="bi bi-chat-heart-fill"></i>
                    </div>

                  </div>

                  <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>

                    <!-- Rating -->

                    <div class="rating-section">

                      <label class="review-label">
                        Rating
                      </label>

                      <div class="rating-slider-box">

                        <span>⭐</span>

                        <input type="range" min="1" max="5" value="3" id="rating" name="review[rating]">

                        <span id="ratingValue">3</span>

                      </div>

                    </div>

                    <!-- Comment -->

                    <div class="comment-section">

                      <label class="review-label">
                        Your comments
                      </label>

                      <textarea id="comment" name="review[comment]" rows="6" required
                        placeholder="What did you like? What could be improved?"></textarea>

                      <div class="invalid-feedback">
                        Please write your review before submitting.
                      </div>

                    </div>

                    <button class="submit-review-btn">

                      <i class="bi bi-send-fill"></i>

                      Publish Review

                    </button>

                  </form>

                </div>

              </div>

              <script>

                const slider = document.getElementById("rating");
                const value = document.getElementById("ratingValue");

                slider.addEventListener("input", () => {

                  value.innerText = slider.value;

                });

              </script>

              <% } %>



                <!-- --------------------------------------- -->
                <div class="show-listing-reviews">
                  <h4 class="reviews-heading">
                    <i class="bi bi-chat-dots-fill"></i> Reviews
                  </h4>

                  <% if (reviews && reviews.length) { %>

                    <div class="reviews-grid">

                      <% reviews.forEach(review=> { %>

                        <div class="review-card">

                          <div class="review-top">

                            <div class="review-user">

                              <div class="review-avatar">
                                <%= review.username.charAt(0).toUpperCase() %>
                              </div>

                              <div>
                                <h6>
                                  <%= review.username %>
                                </h6>

                                <small>
                                  <%= new Date(review.created_at).toLocaleDateString("en-IN", { day: "numeric" ,
                                    month: "long" , year: "numeric" }) %>
                                </small>
                              </div>

                            </div>

                            <div class="review-rating">
                              ⭐ <%= review.rating %>/5
                            </div>

                          </div>

                          <p class="review-comment">
                            <%= review.comment %>
                          </p>
                          <hr>

                          <% if (review.username==curr_user.username) { %>
                            <!-- <hr> -->
                            <form method="POST"
                              action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                              <!-- <button class="btn btn-primary">Delete</button> -->
                              <button class="d-button">
                                <svg viewBox="0 0 448 512" class="svgIcon">
                                  <path
                                    d="M135.2 17.7L128 32H32C14.3 32 0 46.3 0 64S14.3 96 32 96H416c17.7 0 32-14.3 32-32s-14.3-32-32-32H320l-7.2-14.3C307.4 6.8 296.3 0 284.2 0H163.8c-12.1 0-23.2 6.8-28.6 17.7zM416 128H32L53.2 467c1.6 25.3 22.6 45 47.9 45H346.9c25.3 0 46.3-19.7 47.9-45L416 128z">
                                  </path>
                                </svg>
                              </button>
                            </form>
                            <% } %>

                        </div>

                        <% }) %>

                    </div>

                    <% } else { %>

                      <div class="no-reviews">
                        <i class="bi bi-chat-square-text"></i>
                        <p>No reviews yet.</p>
                      </div>

                      <% } %>
                </div>

          </div>

          <!-- Booking -->
          <div class="show-listing-booking">

            <div class="booking-card booking-card-desktop">

              <h3>Reserve your stay</h3>

              <p class="booking-subtitle">
                Secure your booking in just a few clicks.
              </p>

              Pricing: <strong> ₹ <%= listing.price %></strong> / night
              <span class="tooltip-ibtn" tabindex="0" aria-label="Pricing info">
                <i class="bi bi-info-circle-fill ibtn"></i>
                <span class="tooltip-text">
                  <span class="text-primary">18% GST + 2% Platform Fee of the booking price (Base Price) applicable at
                    the
                    time of booking</span>
                </span>
              </span>
              <br>
              <br>
              <!-- Book Now -->
              <form action="/listings/<%= listing._id %>/book" method="get">

                <% if (bookingdata) { %>
                  <input type="hidden" name="bookingdata" value='<%= JSON.stringify(bookingdata) %>'>
                  <% } %>

                    <button type="submit" class="booking-btn">
                      Reserve Now
                    </button>

              </form>
              <hr>

              <% if(currUser && currUser._id.equals(listing.owner._id)){ %>

                <div class="owner-actions">

                  <a href="/listings/<%= listing._id %>/edit" class="edit-btn">

                    Edit Listing

                  </a>

                  <button type="button" class="delete-btn" data-bs-toggle="modal" data-bs-target="#deleteModal">

                    Delete Listing

                  </button>

                </div>

                <% } %>

            </div>

            <!-- // host details -->
            <div class="host-card">

              <div class="host-card-header">

                <div class="host-profile">

                  <img src="<%= listing.owner.profilePhoto.url %>" alt="<%= listing.owner.username %>"
                    class="host-profile-img">

                  <div>

                    <h3>
                      <%= listing.owner.username %>
                    </h3>

                    <span class="host-badge">
                      <i class="bi bi-patch-check-fill"></i>
                      Verified Host
                    </span>

                  </div>

                </div>

              </div>

              <hr>

              <div class="host-info">

                <div class="host-info-item">
                  <i class="bi bi-envelope-fill"></i>
                  <div class="user-info">
                    <small>Email</small>
                    <p>
                      <%= listing.owner.email %>
                    </p>
                  </div>
                </div>
                <div class="host-info-item">
                  <i class="bi bi-person-circle"></i>
                  <div class="user-info">
                    <small>Username</small>
                    <p>@<%= listing.owner.username %>
                    </p>
                  </div>

                </div>


                <% if (currUser && currUser.username !==listing.owner.username) { %>

                  <div class="view-profile-btn-wrapper">
                    <a href="/userprofile/<%= listing.owner._id %>" class="view-profile-btn">
                      <i class="bi bi-person-circle"></i>
                      View Host Profile
                    </a>
                  </div>

                  <% } %>

              </div>

            </div>


            <!-- <p><strong>Phone:</strong> <%= listing.owner.phone %></p> -->
          </div>

          <!-- Delete Confirmation Modal -->
          <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
            <div class="modal-dialog">
              <form id="deleteForm" action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body">
                    <p>All data for this Staycation will be permanently deleted. This action cannot be reverted.</p>
                    <p>Type <b>DELETE</b> to confirm:</p>
                    <input type="text" id="deleteConfirmInput" class="form-control" placeholder="Type DELETE to confirm"
                      required>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger" id="confirmDeleteBtn" disabled>Delete</button>
                  </div>
                </div>
              </form>
            </div>
          </div>


    </body>


    <script>
      const deleteInput = document.getElementById('deleteConfirmInput');
      const deleteBtn = document.getElementById('confirmDeleteBtn');

      deleteInput.addEventListener('input', () => {
        deleteBtn.disabled = deleteInput.value !== 'DELETE';
      });
    </script>



    <script>
      function showdeletemodel(id) {
        if (confirm("Are you sure you want to delete this listing? This action cannot be undone.")) {
          // alert("Deleted Successfully");
          // window.location.href=`/listings/${id}/delete`;
        }
      }
    </script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">


    <script src="/js/map.js"></script>