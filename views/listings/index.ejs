<% layout("/layouts/boilerplate") %>
  <% block('styles').append('<link rel="stylesheet" href="/css/listings_index.css">') %>
    <% const activeSearch=typeof searchedLocation !=="undefined" ? searchedLocation : "" ; const activeTag=typeof
      selectedTag !=="undefined" ? selectedTag : "" ; const hasListings=Array.isArray(listings) && listings.length> 0;
      const headingText = activeTag
      ? `${activeTag.toUpperCase()} LISTINGS`
      : activeSearch
      ? `RESULTS FOR "${activeSearch.toUpperCase()}"`
      : "ALL LOCATION'S";
      const tagFilters = [
      { name: "Trending", icon: "fa-solid fa-ranking-star" },
      { name: "Rooms", icon: "fa-solid fa-bed" },
      { name: "Iconic", icon: "fa-solid fa-mountain-city" },
      { name: "Mountain", icon: "fa-solid fa-mountain-sun" },
      { name: "Castles", icon: "fa-brands fa-fort-awesome" },
      { name: "Pools", icon: "fa-solid fa-person-swimming" },
      { name: "Camping", icon: "fa-solid fa-campground" },
      { name: "Farms", icon: "fa-solid fa-cow" },
      { name: "Hot", icon: "fa-solid fa-fire" },
      { name: "Domes", icon: "fa-solid fa-landmark-dome" }
      ];
      const activeBookingData = typeof bookingdata !== "undefined" && bookingdata ? bookingdata : null;
      const activeCheckIn = activeBookingData && activeBookingData.checkIn ? activeBookingData.checkIn : "";
      const activeCheckOut = activeBookingData && activeBookingData.checkOut ? activeBookingData.checkOut : "";
      %>

      <body>
        <br />

        <div class="filters-toolbar">

          <div class="filter-search-wrap">
            <div class="inputBox_container">
              <svg class="search_icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" alt="search icon">
                <path
                  d="M46.599 46.599a4.498 4.498 0 0 1-6.363 0l-7.941-7.941C29.028 40.749 25.167 42 21 42 9.402 42 0 32.598 0 21S9.402 0 21 0s21 9.402 21 21c0 4.167-1.251 8.028-3.342 11.295l7.941 7.941a4.498 4.498 0 0 1 0 6.363zM21 6C12.717 6 6 12.714 6 21s6.717 15 15 15c8.286 0 15-6.714 15-15S29.286 6 21 6z">
                </path>
              </svg>
              <form action="/listings/searchatlistings" method="GET" class="allLForm" id="searchForm">
                <input class="inputBox inputBox_search" id="inputBox" type="text" name="location" placeholder="Location"
                  value="<%= activeSearch %>" />
              </form>

              <script>
                const input = document.getElementById("inputBox");
                const form = document.getElementById("searchForm");

                let timer;

                input.addEventListener("input", () => {
                  clearTimeout(timer);

                  timer = setTimeout(() => {
                    form.submit();
                  }, 3000); // waits 3000ms after user stops typing
                });
              </script>
            </div>
            <span class="inputBox-error"></span>
          </div>

          <div class="deviderrr">
          </div>

          <div class="filter-dropdown-wrap">
            <button type="button" class="filter-dropdown-btn" id="filterDropdownBtn" onclick="toggleFilterDropdown()">
              <i class="fa-solid fa-sliders"></i>
              <span id="filterBtnLabel">
                <%= activeTag ? "Filtered" : "Filter by Category" %>
              </span>
              <i class="fa-solid fa-chevron-down filter-chevron" id="filterChevron"></i>
            </button>

            <div class="active-filter-chip <%= activeTag ? 'show-chip' : 'hide-chip' %>" id="activeFilterChip">

              <span id="activeFilterLabel">
                <%= activeTag %>
              </span>

              <a class="chip-close-btn" href="/listings" title="Remove filter">
                <i class="fa-solid fa-xmark"></i>
              </a>

            </div>

            <style>
              .active-filter-chip {
                align-items: center;
                gap: 8px;

                padding: 8px 14px;

                border-radius: 50px;

                background: #fff5ec;

                border: 1px solid rgb(255, 155, 73);
              }

              .show-chip {
                display: flex;
              }

              .hide-chip {
                display: none;
              }
            </style>

            <div class="filter-dropdown-panel" id="filterDropdownPanel">
              <p class="filter-dropdown-heading">Select a category</p>
              <div class="filter-grid">
                <% tagFilters.forEach((filter)=> { %>
                  <a class="filter-chip <%= activeTag === filter.name ? 'active-chip' : '' %>"
                    href="/listings/filter?tag=<%= encodeURIComponent(filter.name) %>" data-filter="<%= filter.name %>">
                    <i class="<%= filter.icon %>"></i>
                    <span>
                      <%= filter.name %>
                    </span>
                  </a>
                  <% }) %>
              </div>
            </div>
          </div>

          <div class="deviderrr">
          </div>

          <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
              <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault"
                data-bs-toggle="tooltip" data-bs-placement="top" title="Display price with applicable taxes" />
              <label class="form-check-label" for="flexSwitchCheckDefault"></label>
            </div>
          </div>
<div class="deviderrr">
          </div>
          <!-- -------------Check-in----------Check-out---------------- -->

          <form action="/listings/searchx" method="GET" class="search-form availability-search-form" id="availabilitySearchForm">
            <div class="availability-date-group">
              <div class="availability-field">
                <label for="availabilityCheckIn">Check-in</label>
                <input
                  type="date"
                  id="availabilityCheckIn"
                  name="checkIn"
                  class="form-control availability-date-input"
                  value="<%= activeCheckIn %>"
                  require
                />
              </div>

              <div class="availability-field">
                <label for="availabilityCheckOut">Check-out</label>
                <input
                  type="date"
                  id="availabilityCheckOut"
                  name="checkOut"
                  class="form-control availability-date-input"
                  value="<%= activeCheckOut %>"
                  required
                />
              </div>
            </div>

            <button type="submit" class="btn-search availability-search-btn">Search</button>
          </form>

        </div>

      <script>
        document.addEventListener("DOMContentLoaded", function () {
          var tooltipTriggerList = [].slice.call(document.querySelectorAll("[data-bs-toggle='tooltip']"));
          tooltipTriggerList.forEach(function (tooltipTriggerEl) {
            new bootstrap.Tooltip(tooltipTriggerEl);
          });

          const availabilityForm = document.getElementById("availabilitySearchForm");
          const availabilityCheckIn = document.getElementById("availabilityCheckIn");
          const availabilityCheckOut = document.getElementById("availabilityCheckOut");

          if (!availabilityForm || !availabilityCheckIn || !availabilityCheckOut) {
            return;
          }

          const formatDate = (date) => {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, "0");
            const day = String(date.getDate()).padStart(2, "0");

            return `${year}-${month}-${day}`;
          };

          const getNextDate = (dateValue) => {
            const nextDate = new Date(`${dateValue}T00:00:00`);
            nextDate.setDate(nextDate.getDate() + 1);
            return formatDate(nextDate);
          };

          const today = formatDate(new Date());

          const syncAvailabilityDates = () => {
            availabilityCheckIn.min = today;
            availabilityCheckOut.min = availabilityCheckIn.value
              ? getNextDate(availabilityCheckIn.value)
              : today;

            if (
              availabilityCheckIn.value &&
              availabilityCheckOut.value &&
              availabilityCheckOut.value <= availabilityCheckIn.value
            ) {
              availabilityCheckOut.value = "";
            }

            availabilityCheckOut.setCustomValidity("");
          };

          syncAvailabilityDates();

          availabilityCheckIn.addEventListener("change", syncAvailabilityDates);
          availabilityCheckOut.addEventListener("input", () => {
            availabilityCheckOut.setCustomValidity("");
          });

          availabilityForm.addEventListener("submit", (event) => {
            if (
              availabilityCheckIn.value &&
              availabilityCheckOut.value &&
              availabilityCheckOut.value <= availabilityCheckIn.value
            ) {
              event.preventDefault();
              availabilityCheckOut.setCustomValidity("Check-out must be after check-in.");
              availabilityCheckOut.reportValidity();
            }
          });
        });
      </script>

        <br />
        <h6 class="explore-page-title-ALL-LOCATION">
          <%= headingText %>
        </h6>

        <% if (!hasListings) { %>
          <p class="explore-page-title-ALL-LOCATION">No listings found on this Location, Filter, Dates.</p>
          <% } else { %>
            <div class="row row-cols-lg-3 row-cols-lg-2 row-cols-lg-1 mt-1 card-parent">
              <% for (let LISTING of listings) { %>
                <div class="card" style="width: 20rem">
                  <img src="<%= LISTING.image.url %>" class="card-img-top" alt="listing image" />
                  <div class="card-body">
                    <h6>
                      <%= LISTING.title %>
                    </h6>
                    <h6>
                      <%= LISTING.tag %> | <%= LISTING.location %>
                    </h6>

                    <p class="card-text">
                      &#8377; <%= LISTING.price.toLocaleString("en-IN") %>-/night
                        <i class="taxinfo">
                          +18% GST ( <%= (LISTING.price * 1.18).toLocaleString("en-IN") %> )

                            <span class="tooltip-ibtn">
                              <i class="bi bi-info-circle-fill ibtn"></i>
                              <span class="tooltip-text">
                                2% platform fee (2% of the booking price while booking on a base price of â‚¹ <%=
                                  LISTING.price.toLocaleString("en-IN") %> × days you are booking for)<br>
                              </span>
                            </span>
                        </i>
                    </p>


                    <form action="/listings/<%= LISTING.id %>" method="GET" style="display:inline;">
                      <% if (typeof bookingdata !=="undefined" && bookingdata) { %>
                        <input type="hidden" name="bookingdata" value='<%= JSON.stringify(bookingdata) %>'>
                        <% } %>
                          <button class="noselect" type="submit">
                            <span class="text">Get in</span>
                            <span class="icon">
                              <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="#ffffff">
                                <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
                                <g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g>
                                <g id="SVGRepo_iconCarrier">
                                  <path
                                    d="M14 2H5.50003L4.00003 3.5L6.83581 6.33579L0.585815 12.5858L3.41424 15.4142L9.66424 9.16421L12.5 12L14 10.5L14 2Z"
                                    fill="#ffffff"></path>
                                </g>
                              </svg>


                            </span>


                          </button>
                    </form>

                  </div>
                </div>
                <% } %>
            </div>
            <% } %>

              <br /><br /><br /><br />
      </body>

      <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

      <script>
        const dropdownPanel = document.getElementById("filterDropdownPanel");
        const dropdownBtn = document.getElementById("filterDropdownBtn");
        const filterChevron = document.getElementById("filterChevron");

        function toggleFilterDropdown() {
          const isOpen = dropdownPanel.classList.toggle("open");
          dropdownBtn.classList.toggle("open", isOpen);
          filterChevron.classList.toggle("rotated", isOpen);
        }

        document.addEventListener("click", (e) => {
          if (!dropdownBtn.contains(e.target) && !dropdownPanel.contains(e.target)) {
            dropdownPanel.classList.remove("open");
            dropdownBtn.classList.remove("open");
            filterChevron.classList.remove("rotated");
          }
        });
      </script>
