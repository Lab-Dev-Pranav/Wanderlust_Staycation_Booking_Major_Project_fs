<% layout("/layouts/boilerplate") %>
    <% block('styles').append('<link rel="stylesheet" href="/css/listings_form.css">') %>

        <body class="new-listing">

            <div class="container">
                <h1 class="n-f-h1">Add a New Location</h1>
                <form action="/listings" method="POST" class="needs-validation" novalidate
                    enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input type="text" class="form-control" name="listing[title]" id="title" required
                            placeholder="ex. Beautiful Beach House by PSP Stays">
                        <div class="invalid-feedback">Please provide a title.</div>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea class="form-control" name="listing[description]" id="description" required
                            placeholder="Describe the location..."></textarea>
                        <div class="invalid-feedback">Please provide a description.</div>
                    </div>

                    <div class="mb-3">
                        <label for="price" class="form-label">Price</label>
                        <input class="form-control" name="listing[price]" id="price" required placeholder="ex. 10000">
                        <div class="invalid-feedback">Please provide a valid price.</div>
                    </div>

                    <div class="mb-3">
                        <label for="location" class="form-label">Location</label>
                        <input type="text" class="form-control" name="listing[location]" id="location" required
                            placeholder="ex. lonavala">
                        <div class="invalid-feedback">Please provide a location.</div>
                    </div>

                    <div class="mb-3">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" class="form-control" name="listing[country]" id="country" required
                            placeholder="ex. India">
                        <div class="invalid-feedback">Please provide a country...</div>
                    </div>

                    <!-- //exace lication url -->
                    <div class="mb-3">
                        <label for="exactLocation" class="form-label">Exact Location URL</label>
                        <input type="text" class="form-control" name="listing[exactLocation]" id="exactLocation"
                            required placeholder="ex. https://maps.app.goo.gl/xyz">
                        <div class="invalid-feedback">Please provide an exact location URL.</div>
                    </div>

                    <div class="mb-3">
                        <label for="country" class="form-label">Tag</label>
                        <select name="listing[tag]" class="form-select" aria-label="Default select example" required>
                            <!-- <option selected>Not Selected</option> -->
                            <option value="Trending">Trending</option>
                            <option value="Rooms">Rooms</option>
                            <option value="Iconic">Iconic</option>
                            <option value="Mountain">Mountain</option>
                            <option value="Castles">Castles</option>
                            <option value="Pools">Pools</option>
                            <option value="Camping">Camping</option>
                            <option value="Farms">Farms</option>
                            <option value="Hot">Hot</option>
                            <option value="Domes">Domes</option>
                        </select>
                        <div class="invalid-feedback">Please provide a tag...</div>
                    </div>

                    <!-- <div class="mb-3">
                        <label for="capacity" class="form-label">Capacity</label>
                        <input type="number" class="form-control" name="listing[capacity]" id="capacity" min="1"
                            required placeholder="ex. 10">
                        <div class="invalid-feedback">Please provide a valid capacity.</div>
                    </div> -->


                    <!-- -------------------------------------------- -->
                    <div class="card shadow-sm mt-3">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Room Configuration</h5>

                            <button type="button" class="btn btn-success btn-sm" id="addRoomBtn">
                                + Add Room
                            </button>
                        </div>

                        <div class="card-body">

                            <div id="roomsContainer"></div>

                            <hr>

                            <div class="row">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">
                                        Total Capacity
                                    </label>

                                    <input type="number" id="totalCapacity" name="listing[capacity]" class="form-control"
                                        value="0" readonly>
                                </div>
                            </div>

                        </div>
                    </div>
                    <!-- ------------------------------------------------------- -->
                    <br>


                    <div class="mb-3">
                        <label for="image" class="form-label">Upload Image</label>
                        <input type="file" class="form-control" name="listing[image][url]" id="image">
                        <div class="invalid-feedback">Please provide a valid URL.</div>
                    </div>

                    <button type="submit" class="btn btn-primary">Add New</button>
                </form>
                <br><br><br>
            </div>

        </body>

      <script>
    const roomsContainer = document.getElementById("roomsContainer");
    const addRoomBtn = document.getElementById("addRoomBtn");
    const totalCapacityInput = document.getElementById("totalCapacity");

    let roomCount = 0;

    function createRoom() {

        roomCount++;

        const room = document.createElement("div");
        room.className = "card mb-3 room-card";

        room.innerHTML = `
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Room ${roomCount}</h5>

                <button
                    type="button"
                    class="btn btn-outline-danger btn-sm remove-room">
                    Remove
                </button>
            </div>

            <div class="row">

                <div class="col-md-3 mb-3">
                    <label class="form-label">Room Number</label>

                    <input
                        type="number"
                        class="form-control room-no"
                        name="listing[rooms][${roomCount - 1}][roomNo]"
                        value="${roomCount}"
                        readonly>
                </div>

                <div class="col-md-5 mb-3">
                    <label class="form-label">Room Type</label>

                    <select
                        class="form-select room-type"
                        name="listing[rooms][${roomCount - 1}][roomType]"
                        required>

                        <option value="">Select Room Type</option>

                        <option value="Suite Bedroom">
                            Suite Bedroom
                        </option>

                        <option value="Premium Bedroom">
                            Premium Bedroom
                        </option>

                        <option value="Normal Bedroom" selected>
                            Normal Bedroom
                        </option>

                        <option value="Master Bedroom">
                            Master Bedroom
                        </option>

                        <option value="Kids Bedroom">
                            Kids Bedroom
                        </option>

                        <option value="Guest Room">
                            Guest Room
                        </option>

                        <option value="Dormitory">
                            Dormitory
                        </option>

                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">
                        People Capacity
                    </label>

                    <input
                        type="number"
                        class="form-control room-capacity"
                        name="listing[rooms][${roomCount - 1}][capacity]"
                        min="1"
                        value="1"
                        required>
                </div>

            </div>

        </div>
        `;

        room.querySelector(".remove-room").addEventListener("click", () => {
            room.remove();
            updateRooms();
            updateTotalCapacity();
        });

        room.querySelector(".room-capacity")
            .addEventListener("input", updateTotalCapacity);

        roomsContainer.appendChild(room);

        updateTotalCapacity();
    }

    function updateRooms() {

        const rooms = document.querySelectorAll(".room-card");

        roomCount = 0;

        rooms.forEach(room => {

            roomCount++;

            room.querySelector("h5").textContent = `Room ${roomCount}`;

            room.querySelector(".room-no").value = roomCount;

            room.querySelector(".room-no").name =
                `listing[rooms][${roomCount - 1}][roomNo]`;

            room.querySelector(".room-type").name =
                `listing[rooms][${roomCount - 1}][roomType]`;

            room.querySelector(".room-capacity").name =
                `listing[rooms][${roomCount - 1}][capacity]`;

        });

    }

    function updateTotalCapacity() {

        let total = 0;

        document.querySelectorAll(".room-capacity").forEach(input => {
            total += Number(input.value) || 0;
        });

        totalCapacityInput.value = total;
    }

    addRoomBtn.addEventListener("click", createRoom);

    // Create first room automatically
    createRoom();
</script>