<% layout("/layouts/boilerplate") %>
    <% block('styles').append('<link rel="stylesheet" href="/css/listings_form.css">') %>




        <div class="new-listing-page">

            <!-- Main Form -->
            <form action="/listings" method="POST" enctype="multipart/form-data" class="new-listing-form">

                <!-- ===================================== -->
                <!-- TOP SECTION -->
                <!-- ===================================== -->

                <div class="listing-top-section">

                    <!-- Left Side -->
                    <div class="listing-info-box">

                        <!-- Property Information -->
                        <div class="listing-info-header">

                            <h2>Property Information</h2>

                            <p>
                                Fill in the details below to help guests discover your stay.
                            </p>

                        </div>


                        <div class="listing-info-body">

                            <!-- Title -->

                            <div class="form-field full-width">

                                <label for="title">Property Title</label>

                                <input type="text" class="form-control" id="title" name="listing[title]"
                                    placeholder="Beautiful Beach House by PSP Stays" required>

                                <div class="invalid-feedback">
                                    Please provide a title.
                                </div>

                            </div>


                            <!-- Description -->

                            <div class="form-field full-width">

                                <label for="description">

                                    Description

                                </label>

                                <textarea class="form-control" id="description" name="listing[description]" rows="5"
                                    placeholder="Describe your stay..." required></textarea>

                                <div class="invalid-feedback">
                                    Please provide a description.
                                </div>

                            </div>


                            <!-- Price -->

                            <div class="form-field">

                                <label for="price">

                                    Price (â‚¹ / Night)

                                </label>

                                <input type="number" class="form-control" id="price" name="listing[price]"
                                    placeholder="10000" required>

                                <div class="invalid-feedback">
                                    Please provide a valid price.
                                </div>

                            </div>




                            <!-- Category -->

                            <div class="form-field">

                                <label>

                                    Category

                                </label>

                                <select class="form-select" name="listing[tag]" required>

                                    <option value="">Choose Category</option>

                                    <option value="Trending">Trending</option>

                                    <option value="Rooms">Rooms</option>

                                    <option value="Iconic">Iconic</option>

                                    <option value="Mountain">Mountain</option>

                                    <option value="Castles">Castles</option>

                                    <option value="Pools">Pools</option>

                                    <option value="Camping">Camping</option>

                                    <option value="Farms">Farms</option>

                                    <option value="Hot">Hot</option>

                                    <option value="Domes">Domes</option>

                                </select>

                                <div class="invalid-feedback">
                                    Please select a category.
                                </div>

                            </div>


                            <!-- Location -->

                            <div class="form-field">

                                <label for="location">

                                    City / Location

                                </label>

                                <input type="text" class="form-control" id="location" name="listing[location]"
                                    placeholder="Lonavala" required>

                                <div class="invalid-feedback">
                                    Please provide a location.
                                </div>

                            </div>


                            <!-- Country -->

                            <div class="form-field">

                                <label for="country">

                                    Country

                                </label>

                                <input type="text" class="form-control" id="country" name="listing[country]"
                                    placeholder="India" required>

                                <div class="invalid-feedback">
                                    Please provide a country.
                                </div>

                            </div>





                            <!-- Google Maps -->

                            <div class="form-field full-width">

                                <label for="exactLocation">

                                    Google Maps Location

                                </label>

                                <input type="text" class="form-control" id="exactLocation" name="listing[exactLocation]"
                                    placeholder="https://maps.app.goo.gl/..." required>

                                <div class="invalid-feedback">
                                    Please provide the Google Maps URL.
                                </div>

                            </div>

                        </div>

                    </div>


                    <!-- Right Side -->
                    <div class="listing-upload-box">

                        <!-- Upload Image -->
                        <div class="listing-upload-box">

                            <div class="upload-header">

                                <h2>Property Images</h2>

                                <p>
                                    Upload a high-quality cover photo for your stay.
                                </p>

                            </div>


                            <div class="upload-body">

                                <label for="image" class="image-upload-label">

                                    <div class="image-upload-box">

                                        <div class="upload-icon">
                                            <i class="fa-solid fa-cloud-arrow-up"></i>
                                        </div>

                                        <h4>Choose an Image</h4>

                                        <p>
                                            Drag & Drop
                                            <br>
                                            or
                                            <br>
                                            Click to Browse
                                        </p>

                                    </div>

                                </label>

                                <input type="file" id="image" name="listing[image][url]" accept="image/*" hidden>


                                <!-- Preview -->

                                <div class="image-preview-container">

                                    <img id="imagePreview" src="" alt="Image Preview">

                                </div>

                            </div>

                        </div>

                    </div>

                </div>




                <!-- ===================================== -->
                <!-- Add amenities  -->
                <!-- ===================================== -->

                <div class="listing-amenities-box">

                    <div class="listing-amenities-box-head">


                    </div>
                    <div class="listing-amenities-box-tags">
                        <!-- TAG SET 1 -->
                        <div class="category-grid">
                            <% holidayCategories.forEach((category, index) => { %>
        
                                <div class="category-card">
                                    <!-- From Uiverse.io by risabbir -->
                                    <div class="checkbox-container">
                                        <div class="checkbox-wrapper">
                                            <input  class="checkbox" id="holiday-category-<%= index %>" type="checkbox" value="<%= category.name %>" name="listing[checkboxAMFET][]"  />
                                            <label class="checkbox-label" for="holiday-category-<%= index %>">
                                                <div class="checkbox-flip">
                                                    <div class="checkbox-front">
                                                        <svg fill="white" height="32" width="32" viewBox="0 0 24 24"
                                                            xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M19 13H12V19H11V13H5V12H11V6H12V12H19V13Z"
                                                                class="icon-path"></path>
                                                        </svg>
                                                    </div>
                                                    <div class="checkbox-back">
                                                        <svg fill="white" height="32" width="32" viewBox="0 0 24 24"
                                                            xmlns="http://www.w3.org/2000/svg">
                                                            <path
                                                                d="M9 19l-7-7 1.41-1.41L9 16.17l11.29-11.3L22 6l-13 13z"
                                                                class="icon-path"></path>
                                                        </svg>
                                                    </div>
                                                </div>
                                            </label>
                                            <label for="holiday-category-<%= index %>" class="c_lable"> <%= category.name %> </label>
                                        </div>
                                    </div>

                                </div>
                                <% }) %>
                        </div>



                        <hr>

                        <!-- TAG SET 2 -->
                        <div class="category-grid">
                            <% amenities.forEach((category, index)=> { %>
                                <div class="category-card">
                                    <!-- From Uiverse.io by risabbir -->
                                    <div class="checkbox-container">
                                        <div class="checkbox-wrapper">
                                            <input  class="checkbox" id="amenity-category-<%= index %>" type="checkbox" value="<%= category.name %>" name="listing[checkboxAMFET][]"  />
                                            <label class="checkbox-label" for="amenity-category-<%= index %>">
                                                <div class="checkbox-flip">
                                                    <div class="checkbox-front">
                                                        <svg fill="white" height="32" width="32" viewBox="0 0 24 24"
                                                            xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M19 13H12V19H11V13H5V12H11V6H12V12H19V13Z"
                                                                class="icon-path"></path>
                                                        </svg>
                                                    </div>
                                                    <div class="checkbox-back">
                                                        <svg fill="white" height="32" width="32" viewBox="0 0 24 24"
                                                            xmlns="http://www.w3.org/2000/svg">
                                                            <path
                                                                d="M9 19l-7-7 1.41-1.41L9 16.17l11.29-11.3L22 6l-13 13z"
                                                                class="icon-path"></path>
                                                        </svg>
                                                    </div>
                                                </div>
                                            </label>
                                            <label for="amenity-category-<%= index %>" class="c_lable"> <%= category.name %> </label>
                                        </div>
                                    </div>

                                </div>
                                <% }) %>

                        </div>
                        <hr>
                        <!-- TAG SET 3 -->
                        <div class="category-grid">
                            <% experiences.forEach((category, index)=> { %>
                               <div class="category-card">
                                    <!-- From Uiverse.io by risabbir -->
                                    <div class="checkbox-container">
                                        <div class="checkbox-wrapper">
                                            <input  class="checkbox" id="experience-category-<%= index %>" type="checkbox" value="<%= category.name %>" name="listing[checkboxAMFET][]"  />
                                            <label class="checkbox-label" for="experience-category-<%= index %>">
                                                <div class="checkbox-flip">
                                                    <div class="checkbox-front">
                                                        <svg fill="white" height="32" width="32" viewBox="0 0 24 24"
                                                            xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M19 13H12V19H11V13H5V12H11V6H12V12H19V13Z"
                                                                class="icon-path"></path>
                                                        </svg>
                                                    </div>
                                                    <div class="checkbox-back">
                                                        <svg fill="white" height="32" width="32" viewBox="0 0 24 24"
                                                            xmlns="http://www.w3.org/2000/svg">
                                                            <path
                                                                d="M9 19l-7-7 1.41-1.41L9 16.17l11.29-11.3L22 6l-13 13z"
                                                                class="icon-path"></path>
                                                        </svg>
                                                    </div>
                                                </div>
                                            </label>
                                            <label for="experience-category-<%= index %>" class="c_lable"> <%= category.name %> </label>
                                        </div>
                                    </div>

                                </div>
                                <% }) %>
                        </div>

                        <hr>
                        <!-- TAG SET 4 -->

                        <div class="category-grid">
                            <% attractions.forEach((category, index)=> { %>
                                <div class="category-card">
                                    <!-- From Uiverse.io by risabbir -->
                                    <div class="checkbox-container">
                                        <div class="checkbox-wrapper">
                                            <input  class="checkbox" id="attraction-category-<%= index %>" type="checkbox" value="<%= category.name %>" name="listing[checkboxAMFET][]"  />
                                            <label class="checkbox-label" for="attraction-category-<%= index %>">
                                                <div class="checkbox-flip">
                                                    <div class="checkbox-front">
                                                        <svg fill="white" height="32" width="32" viewBox="0 0 24 24"
                                                            xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M19 13H12V19H11V13H5V12H11V6H12V12H19V13Z"
                                                                class="icon-path"></path>
                                                        </svg>
                                                    </div>
                                                    <div class="checkbox-back">
                                                        <svg fill="white" height="32" width="32" viewBox="0 0 24 24"
                                                            xmlns="http://www.w3.org/2000/svg">
                                                            <path
                                                                d="M9 19l-7-7 1.41-1.41L9 16.17l11.29-11.3L22 6l-13 13z"
                                                                class="icon-path"></path>
                                                        </svg>
                                                    </div>
                                                </div>
                                            </label>
                                            <label for="attraction-category-<%= index %>" class="c_lable"> <%= category.name %> </label>
                                        </div>
                                    </div>

                                </div>
                                <% }) %>

                        </div>



                    </div>



                </div>



                <!-- ===================================== -->
                <!-- ROOM CONFIGURATION -->
                <!-- ===================================== -->

                <div class="listing-room-box">

                    <div class="room-header">

                        <div>

                            <h2>Room Configuration</h2>

                            <p>
                                Add rooms and define the capacity of each room.
                            </p>

                        </div>

                    </div>

                    <div class="room-body">

                        <!-- Existing JS will append room cards here -->
                        <div id="roomsContainer"></div>

                    </div>

                    <div class="room-footer">

                        <button type="button" id="addRoomBtn" class="add-room-btn">

                            <i class="fa-solid fa-plus"></i>

                            Add Room

                        </button>

                        <div class="capacity-box">

                            <span>Total Capacity</span>

                            <input type="number" id="totalCapacity" name="listing[capacity]" value="0" readonly>

                        </div>

                    </div>

                </div>



                <!-- ===================================== -->
                <!-- SUBMIT -->
                <!-- ===================================== -->

                <div class="listing-submit-box">

                    <div class="submit-left">

                        <h3>Ready to Publish?</h3>

                        <p>
                            Review your property information before publishing. You can edit your listing anytime after
                            it's created.
                        </p>

                    </div>

                    <div class="submit-right">

                        <button type="submit" class="publish-btn">

                            <i class="fa-solid fa-paper-plane"></i>

                            Publish Listing

                        </button>

                    </div>

                </div>

            </form>

        </div>






        <script>

            const imageInput = document.getElementById("image");
            const imagePreview = document.getElementById("imagePreview");

            imageInput.addEventListener("change", function () {

                const file = this.files[0];

                if (!file) return;

                const reader = new FileReader();

                reader.onload = function (e) {

                    imagePreview.src = e.target.result;

                    imagePreview.style.display = "block";

                };

                reader.readAsDataURL(file);

            });

        </script>







        <script>
            const roomsContainer = document.getElementById("roomsContainer");
            const addRoomBtn = document.getElementById("addRoomBtn");
            const totalCapacityInput = document.getElementById("totalCapacity");

            let roomCount = 0;

            function createRoom() {

                roomCount++;

                const room = document.createElement("div");
                room.className = "card mb-3 room-card";

                room.innerHTML = `
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Room ${roomCount}</h5>

                <button
                    type="button"
                    class="btn btn-outline-danger btn-sm remove-room">
                    Remove
                </button>
            </div>

            <div class="row">

                <div class="col-md-3 mb-3">
                    <label class="form-label">Room Number</label>

                    <input
                        type="number"
                        class="form-control room-no"
                        name="listing[rooms][${roomCount - 1}][roomNo]"
                        value="${roomCount}"
                        readonly>
                </div>

                <div class="col-md-5 mb-3">
                    <label class="form-label">Room Type</label>

                    <select
                        class="form-select room-type"
                        name="listing[rooms][${roomCount - 1}][roomType]"
                        required>

                        <option value="">Select Room Type</option>

                        <option value="Suite Bedroom">
                            Suite Bedroom
                        </option>

                        <option value="Premium Bedroom">
                            Premium Bedroom
                        </option>

                        <option value="Normal Bedroom" selected>
                            Normal Bedroom
                        </option>

                        <option value="Master Bedroom">
                            Master Bedroom
                        </option>

                        <option value="Kids Bedroom">
                            Kids Bedroom
                        </option>

                        <option value="Guest Room">
                            Guest Room
                        </option>

                        <option value="Dormitory">
                            Dormitory
                        </option>

                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">
                        People Capacity
                    </label>

                    <input
                        type="number"
                        class="form-control room-capacity"
                        name="listing[rooms][${roomCount - 1}][capacity]"
                        min="1"
                        value="1"
                        required>
                </div>

            </div>

        </div>
        `;

                room.querySelector(".remove-room").addEventListener("click", () => {
                    room.remove();
                    updateRooms();
                    updateTotalCapacity();
                });

                room.querySelector(".room-capacity")
                    .addEventListener("input", updateTotalCapacity);

                roomsContainer.appendChild(room);

                updateTotalCapacity();
            }

            function updateRooms() {

                const rooms = document.querySelectorAll(".room-card");

                roomCount = 0;

                rooms.forEach(room => {

                    roomCount++;

                    room.querySelector("h5").textContent = `Room ${roomCount}`;

                    room.querySelector(".room-no").value = roomCount;

                    room.querySelector(".room-no").name =
                        `listing[rooms][${roomCount - 1}][roomNo]`;

                    room.querySelector(".room-type").name =
                        `listing[rooms][${roomCount - 1}][roomType]`;

                    room.querySelector(".room-capacity").name =
                        `listing[rooms][${roomCount - 1}][capacity]`;

                });

            }

            function updateTotalCapacity() {

                let total = 0;

                document.querySelectorAll(".room-capacity").forEach(input => {
                    total += Number(input.value) || 0;
                });

                totalCapacityInput.value = total;
            }

            addRoomBtn.addEventListener("click", createRoom);

            // Create first room automatically
            createRoom();
        </script>



