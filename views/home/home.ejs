<% layout("/layouts/boilerplate") %>
  <% block('styles').append('<link rel="stylesheet" href="/css/home.css">') %>

    <body class="HOME-BODY" style="width:100vw;">

      <div class="home-container" style="max-width: 1400px; width: 95vw; "></div>
      <h1 class=" home-top-title"> Wanderlust Staycation <i>Hosting</i> & <i>Booking</i> </h1>
      <br>
      <br>
      <div class="search-section">
        <div class="search-section-img">
          <img src="other/IMG/homeimg.jpg" alt="homeimg" />
        </div>

        <div class="form-boxaa">
          <h2>Friendly holiday rentals at your <br /><i>Dream Location</i></h2>
          <h2>A place to call home on your next adventure</h2>

          <form action="/search" method="GET" class="search-form" id="searchForm" novalidate>
            <p class="intro-text">Discover dreamy villas, houses, cabins & more</p>

            <div class="input-row">
              <input type="text" name="location" class="form-control" placeholder="Location" required />
              <input type="number" name="people" class="form-control" min="1" placeholder="No. of People" required />
            </div>

            <div class="input-row">
              <input type="date" name="checkIn" class="form-control" id="checkIn" required />
              <input type="date" name="checkOut" class="form-control" id="checkOut" required />
            </div>
            <span class="errorathome"></span>

            <div class="input-row">
              <button type="submit" class="btn-search">Search</button>
            </div>
          </form>
        </div>
      </div>

      <div class="container my-5">

        <!-- 🌟 Home Intro Section -->
        <section class="home-intro p-4 p-md-5 bg-light rounded-4 shadow-sm text-center">
          <h2 class="mb-3">Welcome to Wanderlust</h2>
          <h3 class="mb-4 text-primary">Explore the world with Wanderlust</h3>
          <p>Discover unique stays and experiences around the world.</p>
          <p>From cozy cabins to luxurious villas, we have something for everyone.</p>
          <p>Book your next adventure with us and create unforgettable memories.</p>
          <p>Join our community of travelers and hosts, and experience the world like never before.</p>
          <p>Whether you're looking for a weekend getaway or a long-term stay, we have the perfect place for you.</p>
          <p>Explore our listings and find your dream home away from home.</p>
          <p>Start your journey with Wanderlust today!</p>
          <p>Happy travels!</p>
        </section>

        <% if (currUser) { %>
          <!-- 🌟 Home Owner CTA Section -->
          <section class="home-owner-search mt-5 p-4 p-md-5 bg-primary text-white rounded-4 shadow-sm text-center">
            <h3 class="mb-4">Looking for a place to stay with a friendly host?</h3>
            <p class="mb-4">Book with confidence at your trusted host</p>
            <a class="btn btn-light btn-lg" href="/user">Find Your Host</a>
          </section>
          <% } %>

      </div>



      <div class="container my-5">

        <!-- 🌟 Categories Section -->
        <section class="mb-5">
          <h3 class="text-center mb-4">Holiday rentals for every style</h3>
          <div class="row g-3 justify-content-center">


            <div class="category-grid">

              <% holidayCategories.forEach(category=> { %>

                <div class="category-card">

                  <div class="category-icon">
                    <%= category.icon %>
                  </div>

                  <h5 class="category-title">
                    <%= category.name %>
                  </h5>

                </div>

                <% }) %>

            </div>


          </div>
        </section>

        <!-- 🌟 Amenities Section -->
        <section class="mb-5">
          <h3 class="text-center mb-4">Popular amenities for friendly home rentals</h3>
          <div class="row g-3 justify-content-center">


            <div class="category-grid">

              <% amenities.forEach(category=> { %>

                <div class="category-card">

                  <div class="category-icon">
                    <%= category.icon %>
                  </div>

                  <h5 class="category-title">
                    <%= category.name %>
                  </h5>

                </div>

                <% }) %>

            </div>


          </div>
        </section>

        <!-- 🌟 Experiences Section -->
        <section class="mb-5">
          <h3 class="text-center mb-4">Unique Experiences</h3>
          <div class="row g-3 justify-content-center">

            <div class="category-grid">

              <% experiences.forEach(category=> { %>

                <div class="category-card">

                  <div class="category-icon">
                    <%= category.icon %>
                  </div>

                  <h5 class="category-title">
                    <%= category.name %>
                  </h5>

                </div>

                <% }) %>

            </div>

          </div>
        </section>

        <!-- 🌟 Local Attractions Section -->
        <section class="mb-5">
          <h3 class="text-center mb-4">Top Attractions</h3>
          <div class="row g-3 justify-content-center">

            <div class="category-grid">

              <% attractions.forEach(category=> { %>

                <div class="category-card">

                  <div class="category-icon">
                    <%= category.icon %>
                  </div>

                  <h5 class="category-title">
                    <%= category.name %>
                  </h5>

                </div>

                <% }) %>

            </div>

          </div>
        </section>

      </div>

      <style>
        .category-card {
          margin: 10px;
        }
      </style>



    </body>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const checkInInput = document.getElementById('checkIn');
        const checkOutInput = document.getElementById('checkOut');
        const searchForm = document.getElementById('searchForm');
        const errorathome = document.querySelector(".errorathome");


        // Calculate minimum check-in date (10 days from today)
        const today = new Date();
        const minCheckIn = new Date(today);
        minCheckIn.setDate(today.getDate() + 10);

        // Format date as YYYY-MM-DD for input min attribute
        const formatDate = (date) => {
          const year = date.getFullYear();
          const month = String(date.getMonth() + 1).padStart(2, '0');
          const day = String(date.getDate()).padStart(2, '0');
          return `${year}-${month}-${day}`;
        };

        // Set minimum date for check-in
        checkInInput.min = formatDate(minCheckIn);

        // Update check-out min date when check-in changes
        checkInInput.addEventListener('change', function () {
          const checkInDate = new Date(this.value);
          const minCheckOut = new Date(checkInDate);
          minCheckOut.setDate(checkInDate.getDate() + 1);
          checkOutInput.min = formatDate(minCheckOut);

          // If check-out is before new min, clear it
          if (checkOutInput.value && new Date(checkOutInput.value) < minCheckOut) {
            checkOutInput.value = '';
          }
        });

        // Form validation on submit
        searchForm.addEventListener('submit', function (e) {
          const checkInValue = checkInInput.value;
          if (!checkInValue) {
            e.preventDefault();
            // alert('Please select a check-in date');
            errorathome.textContent = "⊘ Choose a check-in date";
            clearreeor()
            return;
          }

          const selectedCheckIn = new Date(checkInValue);
          const todayStart = new Date(today.getFullYear(), today.getMonth(), today.getDate());

          if (selectedCheckIn < minCheckIn) {
            e.preventDefault();
            // alert(`Check-in date must be at least 10 days from today (${formatDate(minCheckIn)} or later)`);
            errorathome.textContent = `Check-in date must be at least 10 days from today (${formatDate(minCheckIn)} or later)`;
            checkInInput.focus();
            clearreeor()
            return;
          }

          const checkOutValue = checkOutInput.value;
          if (!checkOutValue) {
            e.preventDefault();
            // alert('Please select a check-out date');
            errorathome.textContent = `Please select a check-out date`;
            clearreeor()
            return;
          }

          const selectedCheckOut = new Date(checkOutValue);
          if (selectedCheckOut <= selectedCheckIn) {
            e.preventDefault();
            // alert('Check-out date must be after check-in date');
            errorathome.textContent = `Check-out date must be after check-in date`;
            checkOutInput.focus();
            clearreeor()
            return;
          }
        });



        function clearreeor() {
          setTimeout(() => {
            errorathome.textContent = "";
          }, 5000);
        }

      });
    </script>