<% if(success && success.length){ %>
        <div class="alert alert-secondary alert-dismissible fade show" role="alert">
            <%= success %> 
            <span class="timer-badge" style="float: right; background: rgba(0,0,0,0.1); padding: 2px 8px; border-radius: 50%; font-weight: bold; font-size: 12px;">5</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
<% } %>

<% if(error && error.length){ %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= error %> 
        <span class="timer-badge" style="float: right; background: rgba(0,0,0,0.1); padding: 2px 8px; border-radius: 50%; font-weight: bold; font-size: 12px;">5</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" ></button>
    </div>
<% } %>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const alerts = document.querySelectorAll('.alert');
        alerts.forEach(alert => {
            let timeLeft = 5;
            const timerBadge = alert.querySelector('.timer-badge');
            
            const countdown = setInterval(() => {
                timeLeft--;
                if (timerBadge) {
                    timerBadge.textContent = timeLeft;
                }
                
                if (timeLeft <= 0) {
                    clearInterval(countdown);
                    alert.remove();
                }
            }, 1000);
        });
    });
</script>

