<nav class="wl-navbar">

    <div class="wl-container">

        <!-- ========================= -->
        <!-- Logo -->
        <!-- ========================= -->

        <a href="/" class="wl-logo">

            <div class="wl-logo-icon">

                <i class="fa-solid fa-compass"></i>

            </div>

            <div class="wl-logo-text">

                <h3>Wanderlust</h3>

                <p>Hosting & Booking</p>

            </div>

        </a>


        <!-- ========================= -->
        <!-- Hamburger -->
        <!-- ========================= -->

        <button
            class="wl-menu-btn"
            id="menuBtn"
            aria-label="Toggle Menu">

            <span></span>
            <span></span>
            <span></span>

        </button>


        <!-- ========================= -->
        <!-- Navigation -->
        <!-- ========================= -->

        <div class="wl-nav" id="mobileNav">

            <!-- Left Links -->

            <div class="wl-nav-links">

                <a href="/">Home</a>

                <a href="/listings">Explore</a>

                <a href="/listings/new">

                    Add Staycation

                </a>

                <% if(currUser){ %>

                    <a href="/user">

                        Host

                    </a>

                <% } %>

            </div>


            <!-- Right Links -->

            <div class="wl-nav-actions">

                <% if(!currUser){ %>

                    <a href="/signup" class="wl-register">

                        Register

                    </a>

                    <a href="/login" class="wl-login">

                        <i class="fa-solid fa-right-to-bracket"></i>

                        Login

                    </a>

                <% } %>


                <% if(currUser){ %>

                    <a href="/profile" class="wl-profile">

                        <div class="wl-profile-image">

                            <% if(curr_user.profilePhoto && curr_user.profilePhoto.url){ %>

                                <img
                                    src="<%= curr_user.profilePhoto.url %>"
                                    alt="Profile">

                            <% }else{ %>

                                <i class="fa-solid fa-user"></i>

                            <% } %>

                        </div>

                        <div class="wl-profile-info">

                            <span>

                                @<%= currUser.username %>

                            </span>

                            <small>

                                View Profile

                            </small>

                        </div>

                    </a>


                    <a
                        href="/logout"
                        class="wl-logout">

                        <i class="fa-solid fa-right-from-bracket"></i>

                    </a>

                <% } %>

            </div>

        </div>

    </div>

</nav>

<style>
  /* =====================================================
                WANDERLUST NAVBAR
===================================================== */

:root{

    --primary:#f18832;
    --primary-dark:#db7016;

    --dark:#1f2937;
    --text:#555;

    --white:#fff;

    --border:#ececec;

    --shadow:0 12px 35px rgba(0,0,0,.08);

}


/* =====================================================
                    NAVBAR
===================================================== */

.wl-navbar{

    position:sticky;

    top:0;

    z-index:999;

    width:100%;

    background:rgba(255,255,255,.9);

    backdrop-filter:blur(18px);

    border-bottom:1px solid #eee;

}


/* =====================================================
                CONTAINER
===================================================== */

.wl-container{

    width:min(1400px,95%);

    margin:auto;

    height:78px;

    display:flex;

    align-items:center;

    justify-content:space-between;

}


/* =====================================================
                    LOGO
===================================================== */

.wl-logo{

    display:flex;

    align-items:center;

    gap:15px;

    text-decoration:none;

}


.wl-logo-icon{

    width:52px;

    height:52px;

    border-radius:16px;

    display:flex;

    justify-content:center;

    align-items:center;

    background:#fff4eb;

    color:var(--primary);

    font-size:1.5rem;

}


.wl-logo-text h3{

    margin:0;

    color:var(--dark);

    font-size:1.25rem;

    font-weight:700;

}


.wl-logo-text p{

    margin:2px 0 0;

    color:#777;

    font-size:.75rem;

    letter-spacing:1px;

}


/* =====================================================
                NAVIGATION
===================================================== */

.wl-nav{

    display:flex;

    align-items:center;

    justify-content:space-between;

    flex:1;

    margin-left:50px;

}


.wl-nav-links{

    display:flex;

    align-items:center;

    gap:12px;

}


.wl-nav-links a{

    text-decoration:none;

    color:var(--dark);

    font-weight:600;

    padding:11px 18px;

    border-radius:40px;

    transition:.3s;

}


.wl-nav-links a:hover{

    background:#fff3e8;

    color:var(--primary);

}


/* =====================================================
                ACTIONS
===================================================== */

.wl-nav-actions{

    display:flex;

    align-items:center;

    gap:14px;

}


/* =====================================================
                REGISTER
===================================================== */

.wl-register{

    text-decoration:none;

    background:linear-gradient(135deg,#f6a35b,var(--primary));

    color:white;

    padding:12px 22px;

    border-radius:40px;

    font-weight:600;

    transition:.3s;

}


.wl-register:hover{

    transform:translateY(-2px);

}


/* =====================================================
                LOGIN
===================================================== */

.wl-login{

    width:48px;

    height:48px;

    border-radius:50%;

    background:#f5f5f5;

    display:flex;

    justify-content:center;

    align-items:center;

    text-decoration:none;

    color:#444;

    transition:.3s;

}


.wl-login:hover{

    background:#ffe7d0;

    color:var(--primary);

}


/* =====================================================
                PROFILE
===================================================== */

.wl-profile{

    display:flex;

    align-items:center;

    gap:12px;

    text-decoration:none;

    background:#fff4ea;

    padding:6px 15px 6px 6px;

    border-radius:50px;

    transition:.3s;

}


.wl-profile:hover{

    transform:translateY(-2px);

}


.wl-profile-image{

    width:44px;

    height:44px;

    border-radius:50%;

    overflow:hidden;

    background:#fff;

    display:flex;

    justify-content:center;

    align-items:center;

}


.wl-profile-image img{

    width:100%;

    height:100%;

    object-fit:cover;

}


.wl-profile-image i{

    color:#777;

}


.wl-profile-info{

    display:flex;

    flex-direction:column;

}


.wl-profile-info span{

    color:var(--dark);

    font-weight:700;

    font-size:.92rem;

}


.wl-profile-info small{

    color:#777;

    font-size:.72rem;

}


/* =====================================================
                LOGOUT
===================================================== */

.wl-logout{

    width:46px;

    height:46px;

    border-radius:50%;

    background:#f4f4f4;

    display:flex;

    justify-content:center;

    align-items:center;

    color:#444;

    text-decoration:none;

    transition:.3s;

}


.wl-logout:hover{

    color:#fff;

    background:#ef4444;

}


/* =====================================================
            HAMBURGER
===================================================== */

.wl-menu-btn{

    display:none;

    width:50px;

    height:50px;

    border:none;

    background:none;

    cursor:pointer;

    flex-direction:column;

    justify-content:center;

    gap:6px;

}


.wl-menu-btn span{

    width:28px;

    height:3px;

    background:#222;

    border-radius:50px;

    transition:.35s;

}

/* =====================================================
                RESPONSIVE
===================================================== */

@media (max-width:992px){

    .wl-container{

        height:75px;

        position:relative;

    }

    .wl-menu-btn{

        display:flex;

    }

    .wl-nav{

        position:absolute;

        top:90px;

        left:0;

        width:100%;

        background:#fff;

        border-radius:24px;

        box-shadow:0 20px 45px rgba(0,0,0,.12);

        padding:25px;

        margin-left:0;

        display:flex;

        flex-direction:column;

        align-items:stretch;

        gap:25px;

        transform:translateY(-20px);

        opacity:0;

        visibility:hidden;

        pointer-events:none;

        transition:.35s ease;

    }

    .wl-nav.active{

        opacity:1;

        visibility:visible;

        pointer-events:auto;

        transform:translateY(0);

    }

    .wl-nav-links{

        width:100%;

        display:flex;

        flex-direction:column;

        gap:12px;

    }

    .wl-nav-links a{

        width:100%;

        padding:15px 18px;

        border-radius:14px;

        background:#fafafa;

    }

    .wl-nav-links a:hover{

        background:#fff3ea;

    }

    .wl-nav-actions{

        width:100%;

        display:flex;

        flex-direction:column;

        gap:15px;

        padding-top:20px;

        border-top:1px solid #ececec;

    }

    .wl-register{

        width:100%;

        display:flex;

        justify-content:center;

    }

    .wl-login{

        width:100%;

        height:52px;

        border-radius:14px;

    }

    .wl-profile{

        width:100%;

    }

    .wl-logout{

        width:100%;

        height:52px;

        border-radius:14px;

    }

}


/* =====================================================
                MOBILE
===================================================== */

@media (max-width:576px){

    .wl-container{

        width:94%;

    }

    .wl-logo{

        gap:10px;

    }

    .wl-logo-icon{

        width:45px;

        height:45px;

        border-radius:14px;

    }

    .wl-logo-text h3{

        font-size:1rem;

    }

    .wl-logo-text p{

        font-size:.65rem;

    }

    .wl-nav{

        padding:18px;

        top:82px;

    }

}


/* =====================================================
            HAMBURGER ANIMATION
===================================================== */

.wl-menu-btn.active span:nth-child(1){

    transform:translateY(9px) rotate(45deg);

}

.wl-menu-btn.active span:nth-child(2){

    opacity:0;

}

.wl-menu-btn.active span:nth-child(3){

    transform:translateY(-9px) rotate(-45deg);

}

</style>


<script>


const menuBtn=document.getElementById("menuBtn");

const mobileNav=document.getElementById("mobileNav");

menuBtn.addEventListener("click",()=>{

    menuBtn.classList.toggle("active");

    mobileNav.classList.toggle("active");

});


// Close when clicking outside

document.addEventListener("click",(e)=>{

    if(

        !mobileNav.contains(e.target)

        &&

        !menuBtn.contains(e.target)

    ){

        menuBtn.classList.remove("active");

        mobileNav.classList.remove("active");

    }

});


// ESC closes menu

document.addEventListener("keydown",(e)=>{

    if(e.key==="Escape"){

        menuBtn.classList.remove("active");

        mobileNav.classList.remove("active");

    }

});


// Close after clicking a link (mobile)

document.querySelectorAll(".wl-nav a").forEach(link=>{

    link.addEventListener("click",()=>{

        menuBtn.classList.remove("active");

        mobileNav.classList.remove("active");

    });

});


</script>