<% layout("/layouts/boilerplate") %>
<% block('styles').append('<link rel="stylesheet" href="/css/payment.css">') %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<%
  // Sort by check-in
  const sortedRecords = [...accountingRecords].sort(
    (a, b) => new Date(a.booking.checkIn) - new Date(b.booking.checkIn)
  );

  // Calculate totals
  const totalBaseFee = sortedRecords.reduce((sum, record) => sum + record.baseAmount, 0);
  const totalTax = sortedRecords.reduce((sum, record) => sum + record.taxAmount, 0);
  const totalFee = sortedRecords.reduce((sum, record) => sum + record.platformAmount, 0);
  const totalAmount = sortedRecords.reduce((sum, record) => sum + record.totalAmount, 0);
  const totalRecords = sortedRecords.length;
%>

<div class="payment-page">
  <div class="payment-page-shell">
    <header class="payment-hero-card">
      <div class="payment-kicker">Payment History</div>
      <h1 class="payment-title">My Payments <span id="live-date"></span> <span id="live-time"></span></h1>
      <p class="payment-intro">View all your completed payments and booking transactions.</p>

      <div class="payment-stat-strip">
        <div class="payment-stat-pill">
          <span>Total Transactions</span>
          <strong><%= totalRecords %></strong>
        </div>
        <div class="payment-stat-pill payment-stat-pill-success">
          <span>Total Paid</span>
          <strong>₹<%= totalAmount.toLocaleString("en-IN") %></strong>
        </div>
        <div class="payment-stat-pill">
          <span>Base Amount</span>
          <strong>₹<%= totalBaseFee.toLocaleString("en-IN") %></strong>
        </div>
      </div>
    </header>

    <section class="payment-section" id="payments-list">
      <div class="payment-section-head">
        <div>
          <p class="payment-section-kicker">Transaction Records</p>
          <% if (totalRecords !== 0) { %>
            <h2>All Payments – <%= totalRecords %></h2>
          <% } else { %>
            <h2>No payment records yet</h2>
          <% } %>
        </div>
        <div class="payment-count-chip"><%= totalRecords %> total</div>
      </div>

      <% if (totalRecords === 0) { %>
        <div class="payment-empty-state">
          <div class="payment-empty-icon"><i class="bi bi-credit-card"></i></div>
          <h3>No payments found</h3>
          <p>Your payment history will appear here once you complete a booking.</p>
        </div>
      <% } else { %>
        <div class="payment-table-container">
          <table class="payment-table" role="table">
            <thead>
              <tr>
                <th scope="col">Booking</th>
                <th scope="col">Stay Dates</th>
                <th scope="col">Guests</th>
                <th scope="col">Payment Date</th>
                <th scope="col" class="payment-amount-cell">Amount Breakdown</th>
              </tr>
            </thead>
            <tbody>
              <% for (let record of sortedRecords) { %>
                <tr>
                  <td data-label="Booking">
                    <span class="booking-id"><%= record.booking._id %></span>
                  </td>
                  <td data-label="Stay Dates">
                    <div class="stay-dates">
                      <span class="check-in"><i class="bi bi-calendar-check"></i> <%= new Date(record.booking.checkIn).toLocaleDateString("en-IN", { month: "short", day: "numeric", year: "numeric" }) %></span>
                      <span class="check-out"><i class="bi bi-calendar-x"></i> <%= new Date(record.booking.checkOut).toLocaleDateString("en-IN", { month: "short", day: "numeric", year: "numeric" }) %></span>
                    </div>
                  </td>
                  <td data-label="Guests">
                    <span class="guest-count"><i class="bi bi-people-fill"></i> <%= record.booking.people %></span>
                  </td>
                  <td data-label="Payment Date">
                    <span class="payment-date"><i class="bi bi-clock-history"></i> <%= new Date(record.createdAt).toLocaleDateString("en-IN", { year: "numeric", month: "long", day: "numeric" }) %></span>
                  </td>
                  <td data-label="Amount Breakdown" class="payment-amount-cell">
                    <div class="amount-breakdown">
                      <div class="amount-base">Base: <strong>₹<%= record.baseAmount.toLocaleString("en-IN") %></strong></div>
                      <div class="amount-tax"><i class="bi bi-percent"></i> Tax 18%: <strong>₹<%= record.taxAmount.toLocaleString("en-IN") %></strong></div>
                      <div class="amount-fee"><i class="bi bi-cash-stack"></i> Fee 2%: <strong>₹<%= record.platformAmount.toLocaleString("en-IN") %></strong></div>
                      <div class="amount-total"><i class="bi bi-check-circle-fill"></i> Total: <strong>₹<%= record.totalAmount.toLocaleString("en-IN") %></strong></div>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
            <tfoot>
              <tr>
                <td colspan="4" class="text-end"><strong>Totals</strong></td>
                <td class="payment-amount-cell">
                  <div class="amount-breakdown">
                    <div class="amount-base">Base: <strong>₹<%= totalBaseFee.toLocaleString("en-IN") %></strong></div>
                    <div class="amount-tax">Tax 18%: <strong>₹<%= totalTax.toLocaleString("en-IN") %></strong></div>
                    <div class="amount-fee">Fee 2%: <strong>₹<%= totalFee.toLocaleString("en-IN") %></strong></div>
                    <div class="amount-total">Grand Total: <strong>₹<%= totalAmount.toLocaleString("en-IN") %></strong></div>
                  </div>
                </td>
              </tr>
            </tfoot>
          </table>
        </div>
      <% } %>
    </section>
  </div>
</div>

<script>
  function updateDateTime() {
    const now = new Date();
    const dateOptions = { year: 'numeric', month: 'long', day: 'numeric' };
    const timeOptions = { hour: '2-digit', minute: '2-digit', second: '2-digit' };

    document.getElementById('live-date').textContent = now.toLocaleDateString('en-IN', dateOptions) + ' ';
    document.getElementById('live-time').textContent = now.toLocaleTimeString('en-IN', timeOptions);
  }
  updateDateTime();
  setInterval(updateDateTime, 1000);
</script>