<% layout("/layouts/boilerplate") %>

    <body>
        <div class="bookings-container">
            <h1 class="text-center">Hold Your Stay</h1>


            <div class="booking-form">
                <form action="/bookings/<%= listing._id %>" method="POST" id="bookingForm"
                    onsubmit="return validateBookingForm()" novalidate>
                    <p><strong>Details of the property you are holding:</strong></p>
                    <!-- Listing ID -->
            </div>

            <!-- Listing Info -->
            <div class="card shadow-sm border-2 mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Property Details</h5>
                </div>

                <div class="card-body">

                    <div class="mb-4">
                        <label for="listingId" class="form-label">Property ID</label>
                        <input type="text" class="form-control bg-light" id="listingId" name="listingId"
                            value="<%= listing._id %>" readonly>
                    </div>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <h6 class="text-muted mb-1">Title</h6>
                            <p class="fw-semibold mb-0">
                                <%= listing.title %>
                            </p>
                        </div>

                        <div class="col-md-3">
                            <h6 class="text-muted mb-1">Price / Night</h6>
                            <p class="text-success fw-bold fs-5 mb-0">
                                ₹<%= listing.price %>
                            </p>
                        </div>

                        <div class="col-md-3">
                            <h6 class="text-muted mb-1">Capacity</h6>
                            <p class="mb-0">
                                <%= listing.capacity %> People
                            </p>
                        </div>

                        <div class="col-md-6">
                            <h6 class="text-muted mb-1">Location</h6>
                            <p class="mb-0 text-truncate" style="font-size: 2rem; max-width: 100%;">
                                <%= listing.location %>, <%= listing.country %>
                            </p>
                        </div>

                        <div class="col-md-3">
                            <h6 class="text-muted mb-1">Category</h6>
                            <%= listing.tag %>
                        </div>

                        <div class="col-md-3">
                            <h6 class="text-muted mb-1">Host</h6>
                            <p class="mb-0">
                                <%= listing.owner.username %>
                            </p>
                        </div>

                        <div class="col-md-3">
                            <h6 class="text-muted mb-1">Capacity</h6>
                            <p class="mb-0">
                                <%= listing.capacity %> People
                            </p>
                        </div>

                        <div class="show-all-text">
                              <h6 class="text-muted mb-1">Rooms:</h6>
                            <div class="mt-2">
                                <% listing.rooms.forEach(room=> { %>
                                    <span class="badge bg-light text-dark border me-2 mb-2 p-2">
                                        Room <%= room.roomNo %> •
                                            <%= room.roomType %> •
                                                👥 <%= room.capacity %> People
                                    </span>
                                    <% }) %>
                            </div>
                        </div>
                        

                       

                    </div>

                </div>
            </div>

            <hr>

            <!-- Booking Section -->
            <p><strong>Booking Details:</strong></p>

            <div class="mb-3">
                <label for="email" class="form-label">Booking by:</label>
                <input type="email" class="form-control" id="email" name="email" value="<%= currUser.email %>" required
                    readonly style="background-color: #f9f9f9;">
            </div>

            <hr>
            <!-- Dates -->
            <div class="row mb-3">
                <strong>● Booking Notice:</strong>
                <small style="color: #000000; font-size: 17px;">- Check-in date must be at least 10 days from today (As
                    per the system).</small><br>
                <small style="color: #000000; font-size: 17px;">- To secure and confirm your dream stay, please select a
                    check-in date that is at least <strong>12 days</strong> from today.</small><br>
                <small style="color: #000000; font-size: 17px;">- This booking window helps ensure availability, so even
                    if another guest temporarily holds the property and later cancels in next 24 hours by remaning
                    payment as it is (As per the system), you'll still have a better chance of securing your preferred
                    stay in that 2 days at the same time.</small><br><br><br>
                <hr>

                <div class="col-md-4">
                    <label for="checkIn" class="form-label">Check-In Date:</label>
                    <input type="date" class="form-control" id="checkIn" name="checkIn" required
                        value="<%= bookingdata && bookingdata.checkIn ? bookingdata.checkIn : '' %>">
                    <div id="checkInError" class="form-text text-danger d-none"></div>
                </div>
                <div class="col-md-4">
                    <label for="checkOut" class="form-label">Check-Out Date:</label>
                    <input type="date" class="form-control" id="checkOut" name="checkOut" required
                        value="<%= bookingdata && bookingdata.checkOut ? bookingdata.checkOut : '' %>">
                    <div id="checkOutError" class="form-text text-danger d-none"></div>
                </div>
                <div class="col-md-4 d-flex flex-column justify-content-end">
                    <label class="form-label">Total Days:</label>
                    <div id="totalDaysDisplay" class="fw-semibold">--</div>
                </div>

            </div>
            <!-- Span for displaying error messages for check-in and check-out dates must be at least 10 days from today -->
            <small id="dateError" class="text-danger d-none"></small>
            <small id="dateValid" class="text-success d-none"></small>
            <br>
            <small style="color: #6c757d; font-size: 17px;"> ● Check-in at 01:00 PM | Check-out at 11:00 AM</small>
            <hr>
            <!-- People -->

            <div class="mb-3">
                <label for="people" class="form-label">Number of People</label>

                <input type="number" class="form-control" id="people" name="people" min="1" style="width: 200px;"
                    max="<%= listing.capacity %>" required
                    value="<%= bookingdata && bookingdata.people ? bookingdata.people : '' %>"
                    placeholder="<%= listing.capacity %> People or less">

                <small id="peopleError" class="text-danger d-none"></small>

            </div>

            <!-- Price -->
            <div class="form-group">
                <div class="mb-3">
                    <label for="totalPrice" class="form-label">
                        Total Price <span class="text-muted">(incl. 18% GST + 2% Platform Fee)</span>
                    </label>

                    <input type="text" class="form-control bg-light" id="totalPrice" name="totalPrice"
                        placeholder="Total price will be calculated automatically based on your booking duration"
                        readonly>

                </div>

                <div id="gstPriceDisplay" style="font-weight: bold; color: #28a745;">-------</div>
                <p><strong>Note:</strong> You are temporarily holding this property. To confirm your booking, please
                    complete the
                    payment from your profile section in the next 24 hours.</p>
            </div>

            <br>
            <button type="submit" id="submitbtn" class="btn btn-primary" disabled>Hold Your Booking</button>
            <br>
            <br><br>
            </form>
        </div>
        </div>
    </body>

    <script>
        const peopleInput = document.getElementById('people');
        const peopleError = document.getElementById('peopleError');
        const maxCapacity = Number('<%= listing.capacity %>');

        const checkInInput = document.getElementById('checkIn');
        const checkOutInput = document.getElementById('checkOut');
        const totalPriceInput = document.getElementById('totalPrice');
        const gstPriceDisplay = document.getElementById('gstPriceDisplay');
        const submitbtn = document.getElementById('submitbtn');


        const pricePerNight = Number('<%= listing.price %>');

        // Validate number of people 
        peopleInput.addEventListener('input', () => {
            const value = parseInt(peopleInput.value);
            if (!value || value < 1 || value > maxCapacity) {
                peopleError.textContent = `Number of people must be between 1 and ${maxCapacity}.`;
                peopleError.style.display = 'block';
            } else {
                peopleError.style.display = 'none';
            }
        });

        // Real-time update on date input
        checkInInput.addEventListener('change', () => {
            datevalidate();
        });
        checkOutInput.addEventListener('change', () => {
            datevalidate();
        });


        // Validate dates and then call calculate total price
        function datevalidate() {
            const dateError = document.getElementById('dateError');
            const dateValid = document.getElementById('dateValid');
            const todaydate = new Date();
            dateError.classList.add("d-none");
            dateError.textContent = "";
            dateValid.classList.add("d-none");
            dateValid.textContent = "";

            const checkIn = new Date(checkInInput.value);
            const checkOut = new Date(checkOutInput.value);

            // Today's date (time removed)
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            // Minimum booking date = Today + 10 days total 10 days from today
            const minBookingDate = new Date(today);
            minBookingDate.setDate(minBookingDate.getDate() + 10);

            // Check Check-In
            if (checkInInput.value && checkIn < minBookingDate) {
                dateError.textContent = `⊘ Check-in date must be at least 10 days from today. You can hold booking from the date (${minBookingDate.toISOString().split('T')[0]})`;
                clearPrice();
                dateError.classList.remove("d-none");
                checkInInput.classList.add("is-invalid");
                return;
            } else if (checkInInput.value && checkIn >= minBookingDate) {
                dateValid.textContent = "✓ Check-in date is valid.";
                dateValid.classList.remove("d-none");
                checkInInput.classList.remove("is-invalid");
                checkInInput.removeEventListener('change', datevalidate);
            }

            // Check Check-Out
            if (checkOutInput.value && checkOut < minBookingDate) {
                dateError.textContent = `⊘ Check-out date must be at least 10 days from today. You can hold booking from the date (${minBookingDate.toISOString().split('T')[0]})`;
                clearPrice();
                dateError.classList.remove("d-none");
                checkOutInput.classList.add("is-invalid");
                return;
            } else if (checkOutInput.value && checkOut >= minBookingDate) {
                dateValid.textContent = "✓ Check-out date is valid.";
                dateValid.classList.remove("d-none");
                checkOutInput.classList.remove("is-invalid");
            }

            // Check Check-Out after Check-In
            if (checkInInput.value && checkOutInput.value && checkOut <= checkIn) {
                dateError.textContent = "⊘ Check-out date must be after the check-in date.";
                clearPrice();
                dateError.classList.remove("d-none");
                checkOutInput.classList.add("is-invalid");

                return;
            } else {
                checkOutInput.classList.remove("is-invalid");
            }
            calculateTotalPrice();
        }

        // Calculate total price based on check-in and check-out dates
        function calculateTotalPrice() {

            const totalDaysDisplay = document.getElementById('totalDaysDisplay');

            if (checkInInput.value && checkOutInput.value) {
                const checkInDate = new Date(checkInInput.value);
                const checkOutDate = new Date(checkOutInput.value);

                const timeDiffDays = Math.floor((checkOutDate - checkInDate) / (1000 * 60 * 60 * 24));

                if (timeDiffDays > 0) {
                    const basePrice = pricePerNight * timeDiffDays;
                    const gstAmount = basePrice * 0.18;
                    const platformFee = basePrice * 0.02; // 2% of base price
                    const totalAmount = basePrice + gstAmount + platformFee;

                    totalPriceInput.value = `₹ ${basePrice.toLocaleString("en-IN")} /-`;
                    gstPriceDisplay.innerHTML = `
                ₹ ${totalAmount.toLocaleString("en-IN", {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    })} /- <br>
                <small style="color: #6c757d;">
                    (₹ ${basePrice.toLocaleString("en-IN")} base + ₹ ${gstAmount.toFixed(2)} GST + ₹ ${platformFee.toFixed(2)} platform fee)
                </small>
            `;
                    totalDaysDisplay.textContent = `${timeDiffDays} day${timeDiffDays > 1 ? 's' : ''}`;

                    // submitbtn.removeAttribute("disabled");
                    // submitbtn.addAttribute("disabled");
                    submitbtn.disabled = false;

                } else {
                    totalPriceInput.value = "Invalid Date Range";
                    gstPriceDisplay.innerHTML = "-------";
                    totalDaysDisplay.textContent = "-------";
                    submitbtn.disabled = true;
                }
            } else {
                totalDaysDisplay.textContent = "-------";
                totalPriceInput.value = "";
                gstPriceDisplay.innerHTML = "-------";
                submitbtn.disabled = true;
            }
        }

        // Clear price and GST display when dates are invalid
        function clearPrice() {
            totalPriceInput.value = "";
            gstPriceDisplay.innerHTML = "-------";
            totalDaysDisplay.textContent = "-------";
            submitbtn.disabled = true;
        }


        // Final form validation before submit
        function validateBookingForm() {
            let valid = true;

            const checkInError = document.getElementById('checkInError');
            const checkOutError = document.getElementById('checkOutError');
            checkInError.style.display = 'none';
            checkOutError.style.display = 'none';

            if (!checkInInput.value) {
                checkInError.textContent = "Please select a check-in date.";
                checkInError.style.display = 'block';
                valid = false;
            }

            if (!checkOutInput.value) {
                checkOutError.textContent = "Please select a check-out date.";
                checkOutError.style.display = 'block';
                valid = false;
            }

            if (checkInInput.value && checkOutInput.value) {
                const checkInDate = new Date(checkInInput.value);
                const checkOutDate = new Date(checkOutInput.value);
                if (checkOutDate <= checkInDate) {
                    checkOutError.textContent = "⊘ Check-out date must be after check-in date.";
                    checkOutError.style.display = 'block';
                    valid = false;
                }
            }

            const peopleCount = parseInt(peopleInput.value);
            if (!peopleCount || peopleCount < 1 || peopleCount > maxCapacity) {
                peopleError.textContent = `⊘ Number of people must be between 1 and ${maxCapacity}.`;
                peopleError.style.display = 'block';
                valid = false;
            }

            return valid;
        }







        //     const checkInInput = document.getElementById('checkIn');
        //     const checkOutInput = document.getElementById('checkOut');
        const checkInError = document.getElementById('checkInError');
        const checkOutError = document.getElementById('checkOutError');
        const totalDaysDisplay = document.getElementById('totalDaysDisplay');

        const MS_PER_DAY = 1000 * 60 * 60 * 24;

        // Print today’s date in YYYY-MM-DD format
        const today = new Date();
        const formattedToday = today.toISOString().split('T')[0];

        function validateDates() {
            const checkInDate = new Date(checkInInput.value);
            const checkOutDate = new Date(checkOutInput.value);
            let isValid = true;

            // Validate Check-In at least 15 days from today
            const diffFromToday = Math.floor((checkInDate - today) / MS_PER_DAY);
            if (diffFromToday < 15) {
                checkInError.textContent = "⊘ Check-in must be at least 15 days from today.";
                checkInError.style.display = "block";
                isValid = false;
            } else {
                checkInError.textContent = "";
                checkInError.style.display = "none";
            }

            // Validate Check-Out after Check-In
            if (checkOutDate <= checkInDate) {
                checkOutError.textContent = "⊘ Check-out must be after Check-in.";
                checkOutError.style.display = "block";
                isValid = false;
            } else {
                checkOutError.textContent = "";
                checkOutError.style.display = "none";
            }

            // Show total days
            if (checkOutDate > checkInDate) {
                const totalDays = Math.floor((checkOutDate - checkInDate) / MS_PER_DAY);
                totalDaysDisplay.textContent = totalDays + " day(s)";
            } else {
                totalDaysDisplay.textContent = "--";
            }

            return isValid;
        }

        checkInInput.addEventListener('change', validateDates);
        checkOutInput.addEventListener('change', validateDates);

    </script>